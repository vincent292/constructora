# Produccion o remoto
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-public-publishable-key
# Mantener en false o sin definir en produccion para no exponer registro publico al CMS
# VITE_ENABLE_CMS_SIGNUP=false
# VITE_SUPABASE_ANON_KEY=your-legacy-anon-key

# Desarrollo local con Supabase CLI
# VITE_SUPABASE_URL=http://127.0.0.1:54321
# VITE_SUPABASE_ANON_KEY=tu-anon-key-local
# VITE_ENABLE_CMS_SIGNUP=true
